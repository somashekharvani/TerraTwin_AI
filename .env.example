# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database Connection (PostgreSQL or SQLite during local test)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/terratwin?schema=public"

# Authentication
JWT_SECRET="your-super-secret-jwt-signing-key-at-least-32-chars-long"

# Google Gemini API (for Bill OCR & Food Recognition)
GEMINI_API_KEY="your-google-gemini-api-key"

# Pinecone & Vector DB (for Agentic AI Memory)
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_ENVIRONMENT="us-east-1-aws"
PINECONE_INDEX_NAME="terratwin-memory"

# IoT MQTT Broker Configuration
MQTT_BROKER_URL="mqtt://broker.hivemq.com:1883"

# Blockchain / Web3 Configuration (Polygon RPC)
POLYGON_RPC_URL="https://rpc-amoy.polygon.technology"
# The backend wallet private key that signs EcoToken mint actions
BLOCKCHAIN_DISTRIBUTOR_KEY="0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
ECO_TOKEN_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"
